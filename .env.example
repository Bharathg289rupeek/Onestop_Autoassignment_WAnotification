PORT=3000

# Onestop
ONESTOP_JWT=your_jwt_token

# Gupshup WhatsApp
GUPSHUP_API_KEY=your_api_key
GUPSHUP_APP_NAME=your_app_name
GUPSHUP_SOURCE_NUMBER=917834811114
GUPSHUP_TEMPLATE_ID=22a5b3ed-fee2-4c13-baa0-3e653d3aafec
GUPSHUP_REASSIGN_TEMPLATE_ID=your_reassign_template_id_or_same_as_above

# Lead system
